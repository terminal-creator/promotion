# 复制为 .env 后按需修改
# Node 后端监听端口（不是公网端口，Nginx 反代到这里）
PORT=3001

# 公网访问的完整域名（用于生成渠道 URL）
# 例：https://s5-2026.cn  或开发期 http://localhost:3001
PUBLIC_BASE_URL=https://s5-2026.cn

# 数据库文件路径（相对 llmpromotion 根目录）
DB_PATH=./channels.db

# 上传目录路径（相对 llmpromotion 根目录）
UPLOADS_DIR=./uploads/qr

# 每 IP 创建限频：window-ms / max
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1

# QR 图片大小上限（字节）
QR_MAX_SIZE=512000
